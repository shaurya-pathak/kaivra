              "type": "text",
              "id": "code_label",
              "content": "The Loop Invariant",
              "style": "caption"
            },
            {
              "type": "box",
              "id": "code_box",
              "content": "while left <= right:\n    mid = (left + right) // 2\n    if arr[mid] == target: return mid\n    elif arr[mid] < target: left = mid + 1\n    else: right = mid - 1\nreturn -1"
            }
          ],
          "layout": {
