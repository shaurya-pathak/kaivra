  "scenes": [
    {
      "id": "overview",
      "duration": "16s",
      "template": "one-column",
      "auto_visible": false,
      "narration": "Before we zoom into the arithmetic, let's anchor the purpose of forward propagation. At this point the network already has fixed weights and biases. Its job is to take one input example, transform those raw numbers into hidden evidence, and then turn that evidence into a prediction.",
      "objects": [
        {
          "type": "text",
          "id": "overview_title",
          "content": "Forward Propagation in One Pass",
          "style": "heading"
        },
        {
          "type": "group",
          "id": "overview_stack",
          "visible": true,
          "layout": { "type": "stack", "direction": "vertical", "gap": "large", "align": "center" },
          "children": [
            {
              "type": "group",
              "id": "pipeline_row",
              "layout": { "type": "flow", "direction": "horizontal", "gap": "large", "align": "center" },
              "children": [
                { "type": "box", "id": "input_vector", "content": "Input x = [0.70, -0.40]" },
                { "type": "box", "id": "hidden_layer_summary", "content": "Hidden layer: z = W x + b, h = ReLU(z)" },
                { "type": "box", "id": "prediction_summary", "content": "Output: y_hat = sigmoid(logit)" }
              ]
            },
            {
              "type": "group",
              "id": "formula_row",
              "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
              "children": [
                { "type": "token", "id": "formula_sum", "content": "weights scale influence" },
                { "type": "token", "id": "formula_bias", "content": "bias shifts baseline" },
                { "type": "token", "id": "formula_relu", "content": "ReLU keeps positive signal" },
                { "type": "token", "id": "formula_output", "content": "sigmoid makes a probability" }
              ]
            }
          ]
        },
        { "type": "connector", "id": "overview_in_to_hidden", "from": "input_vector", "to": "hidden_layer_summary" },
        { "type": "connector", "id": "overview_hidden_to_out", "from": "hidden_layer_summary", "to": "prediction_summary" }
      ],
      "animations": [
        { "action": "fade-in", "target": "overview_title", "at": "0s", "duration": "0.7s" },
        { "action": "fade-in", "target": "pipeline_row", "at": "0.8s", "duration": "1.0s" },
        { "action": "fade-in", "target": "input_vector", "at": "1.2s", "duration": "0.8s" },
        { "action": "draw", "target": "overview_in_to_hidden", "at": "2.8s", "duration": "1.0s" },
