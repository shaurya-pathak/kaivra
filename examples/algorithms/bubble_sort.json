{
  "version": "1.0",
  "meta": {
    "title": "Bubble Sort on [5, 3, 1, 4]",
    "resolution": [1920, 1080],
    "fps": 30,
    "theme": "whiteboard"
  },
  "scenes": [
    {
      "id": "intro",
      "duration": "4s",
      "layout": "center",
      "narration": "Bubble Sort compares adjacent elements and swaps them when they're out of order. Let's sort 5, 3, 1, 4.",
      "objects": [
        { "type": "text", "id": "title", "content": "Bubble Sort", "style": "heading" },
        { "type": "text", "id": "sub",   "content": "Input: [5, 3, 1, 4]", "style": "caption" }
      ],
      "animations": [
        { "action": "appear", "target": "title", "at": "0s" },
        { "action": "appear", "target": "sub",   "at": "0s" }
      ]
    },

    {
      "id": "swap1",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Compare 5 and 3. 5 is greater — swap.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 1 — Compare 5 and 3", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "s1_t0", "content": "5" },
            { "type": "token", "id": "s1_t1", "content": "3" },
            { "type": "token", "id": "s1_t2", "content": "1" },
            { "type": "token", "id": "s1_t3", "content": "4" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": ["s1_t0", "s1_t1"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" },
        { "action": "move",      "target": "s1_t0",             "at": "2.0s", "duration": "0.8s", "offset_x": 74,  "easing": "ease-in-out" },
        { "action": "move",      "target": "s1_t1",             "at": "2.0s", "duration": "0.8s", "offset_x": -74, "easing": "ease-in-out" }
      ]
    },

    {
      "id": "swap2",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Now 3, 5, 1, 4. Compare 5 and 1. Swap.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 1 — Compare 5 and 1", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "s2_t0", "content": "3" },
            { "type": "token", "id": "s2_t1", "content": "5" },
            { "type": "token", "id": "s2_t2", "content": "1" },
            { "type": "token", "id": "s2_t3", "content": "4" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": ["s2_t1", "s2_t2"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" },
        { "action": "move",      "target": "s2_t1",             "at": "2.0s", "duration": "0.8s", "offset_x": 74,  "easing": "ease-in-out" },
        { "action": "move",      "target": "s2_t2",             "at": "2.0s", "duration": "0.8s", "offset_x": -74, "easing": "ease-in-out" }
      ]
    },

    {
      "id": "swap3",
      "duration": "6s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Now 3, 1, 5, 4. Compare 5 and 4. Swap — and 5 has bubbled to its final position.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 1 — Compare 5 and 4", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "s3_t0", "content": "3" },
            { "type": "token", "id": "s3_t1", "content": "1" },
            { "type": "token", "id": "s3_t2", "content": "5" },
            { "type": "token", "id": "s3_t3", "content": "4" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": ["s3_t2", "s3_t3"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" },
        { "action": "move",      "target": "s3_t2",             "at": "2.0s", "duration": "0.8s", "offset_x": 74,  "easing": "ease-in-out" },
        { "action": "move",      "target": "s3_t3",             "at": "2.0s", "duration": "0.8s", "offset_x": -74, "easing": "ease-in-out" },
        { "action": "highlight", "target": "s3_t2",             "at": "3.0s", "duration": "2.5s", "style": "glow", "color": "success" }
      ]
    },

    {
      "id": "swap4",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Pass 2. Compare 3 and 1. Swap.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 2 — Compare 3 and 1", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "s4_t0", "content": "3" },
            { "type": "token", "id": "s4_t1", "content": "1" },
            { "type": "token", "id": "s4_t2", "content": "4" },
            { "type": "token", "id": "s4_t3", "content": "5" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": "s4_t3",             "at": "0s",   "duration": "5s",  "style": "glow", "color": "success" },
        { "action": "highlight", "target": ["s4_t0", "s4_t1"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" },
        { "action": "move",      "target": "s4_t0",             "at": "2.0s", "duration": "0.8s", "offset_x": 74,  "easing": "ease-in-out" },
        { "action": "move",      "target": "s4_t1",             "at": "2.0s", "duration": "0.8s", "offset_x": -74, "easing": "ease-in-out" }
      ]
    },

    {
      "id": "noswap",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Compare 3 and 4. Already in order — no swap. Pass 2 done.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 2 — Compare 3 and 4", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "s5_t0", "content": "1" },
            { "type": "token", "id": "s5_t1", "content": "3" },
            { "type": "token", "id": "s5_t2", "content": "4" },
            { "type": "token", "id": "s5_t3", "content": "5" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": ["s5_t2", "s5_t3"], "at": "0s",   "duration": "5s",  "style": "glow", "color": "success" },
        { "action": "highlight", "target": ["s5_t1", "s5_t2"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" }
      ]
    },

    {
      "id": "pass3",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Pass 3. Compare 1 and 3 — already in order, no swap. No swaps this pass means the array is sorted.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Pass 3 — Compare 1 and 3", "style": "section-heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "p3_t0", "content": "1" },
            { "type": "token", "id": "p3_t1", "content": "3" },
            { "type": "token", "id": "p3_t2", "content": "4" },
            { "type": "token", "id": "p3_t3", "content": "5" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",           "at": "0s" },
        { "action": "appear",    "target": "arr",               "at": "0s" },
        { "action": "highlight", "target": ["p3_t2", "p3_t3"], "at": "0s",   "duration": "5s",  "style": "glow", "color": "success" },
        { "action": "highlight", "target": ["p3_t0", "p3_t1"], "at": "0.2s", "duration": "1.8s", "style": "glow", "color": "accent" }
      ]
    },

    {
      "id": "sorted",
      "duration": "5s",
      "layout": { "type": "stack", "gap": "large", "align": "center" },
      "narration": "Done. The sorted array is 1, 3, 4, 5.",
      "objects": [
        { "type": "text", "id": "heading", "content": "Sorted!", "style": "heading", "position": "top" },
        {
          "type": "group", "id": "arr",
          "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
          "children": [
            { "type": "token", "id": "f_t0", "content": "1" },
            { "type": "token", "id": "f_t1", "content": "3" },
            { "type": "token", "id": "f_t2", "content": "4" },
            { "type": "token", "id": "f_t3", "content": "5" }
          ]
        }
      ],
      "animations": [
        { "action": "appear",    "target": "heading",                      "at": "0s" },
        { "action": "appear",    "target": "arr",                          "at": "0s" },
        { "action": "highlight", "target": ["f_t0","f_t1","f_t2","f_t3"], "at": "0.5s", "duration": "4s",  "style": "glow", "color": "success" }
      ]
    }
  ]
}
