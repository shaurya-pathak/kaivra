    {
      "id": "add_bias",
      "duration": "25.535s",
      "layout": {
        "type": "center",
        "gap": "medium",
        "direction": "horizontal",
        "align": "center"
      },
      "template": "one-column",
      "narration": "The bias is not just a random extra number. It lets the neuron shift its baseline before the activation function sees the result, which means it controls how easy or hard it is for that neuron to turn on. Here the weighted evidence is zero point four seven, the bias nudges it upward by zero point one zero, and that moves the pre-activation to zero point five seven.",
      "objects": [
        {
