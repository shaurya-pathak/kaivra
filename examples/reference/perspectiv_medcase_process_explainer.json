        { "action": "fade-in", "target": "guide_title", "at": "0s", "duration": "0.8s" },
        { "action": "fade-in", "target": "learner_box", "at": "0.5s", "duration": "0.6s" },
        { "action": "fade-in", "target": "guided_answer", "at": "1.0s", "duration": "0.6s" },
        { "action": "highlight", "target": "guided_answer", "at": "0.8s", "duration": "1.6s", "style": "glow", "color": "success" },
        { "action": "draw", "target": "gu1", "at": "1.9s", "duration": "0.5s" },
        { "action": "fade-in", "target": "progress_box", "at": "2.5s", "duration": "0.6s" },
        { "action": "draw", "target": "gu2", "at": "3.0s", "duration": "0.5s" },
        { "action": "fade-in", "target": ["artifact_trace", "artifact_image", "artifact_lab"], "at": "3.9s", "duration": "0.7s", "stagger": "0.18s" },
        { "action": "fade-in", "target": ["pg_question", "pg_evidence", "pg_next"], "at": "5.4s", "duration": "0.7s", "stagger": "0.18s" },
        { "action": "highlight", "target": ["artifact_trace", "artifact_image", "artifact_lab"], "at": "6.8s", "duration": "1.8s", "style": "glow", "color": "accent", "stagger": "0.18s" },
        { "action": "highlight", "target": ["pg_question", "pg_evidence", "pg_next"], "at": "8.9s", "duration": "1.8s", "style": "glow", "color": "success", "stagger": "0.18s" },
        { "action": "pulse", "target": "progress_box", "at": "10.9s", "duration": "1.0s" }
      ]
    },
    {
      "id": "end_to_end",
      "duration": "16s",
