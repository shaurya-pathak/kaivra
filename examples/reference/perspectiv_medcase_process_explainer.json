          "type": "group",
          "id": "guided_scene",
          "visible": true,
          "layout": { "type": "stack", "direction": "vertical", "gap": "large", "align": "center" },
          "children": [
            {
              "type": "text",
              "id": "guide_title",
              "content": "5. The UI turns reasoning into guided learning",
              "style": "heading"
            },
            {
              "type": "group",
              "id": "guide_main_row",
              "visible": true,
              "layout": { "type": "flow", "direction": "horizontal", "gap": "large", "align": "center" },
              "children": [
                { "type": "box", "id": "learner_box", "content": "Learner UI" },
                { "type": "box", "id": "guided_answer", "content": "Guided answer" },
                { "type": "box", "id": "progress_box", "content": "Progress path" }
              ]
            },
            {
              "type": "group",
              "id": "artifact_row",
              "visible": true,
              "layout": { "type": "flow", "direction": "horizontal", "gap": "small", "align": "center" },
              "children": [
                { "type": "token", "id": "artifact_trace", "content": "ECG trace" },
                { "type": "token", "id": "artifact_image", "content": "Image note" },
                { "type": "token", "id": "artifact_lab", "content": "Lab trend" }
              ]
            },
            {
              "type": "group",
              "id": "progress_tokens",
              "visible": true,
              "layout": { "type": "flow", "direction": "horizontal", "gap": "medium", "align": "center" },
