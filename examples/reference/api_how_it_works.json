    {
      "id": "response_to_client",
      "duration": "12s",
      "template": "one-column",
      "auto_visible": false,
      "include_persistent_objects": true,
      "narration": "Finally, the API turns that payload into an HTTP response. In our example, it sends back two hundred okay plus JSON for user forty-two, and the client reads that contract to render Ava's profile. If the status had been an error instead, the same client could show a retry or failure state.",
      "objects": [
        {
          "type": "group",
          "id": "response_scene",
          "visible": true,
          "children": [
            {
              "type": "text",
              "id": "response_title",
              "content": "4. The API sends a structured response",
              "style": "heading"
            },
            {
              "type": "group",
              "id": "response_flow",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "large",
                "align": "center"
              },
              "children": [
                {
                  "type": "box",
                  "id": "payload_box",
                  "content": "API payload\n{id:42,name:\"Ava\"}"
                },
                {
                  "type": "box",
                  "id": "response_box",
                  "content": "200 OK + JSON"
                },
                {
                  "type": "box",
                  "id": "client_result",
                  "content": "Render Ava profile"
                }
              ]
            },
            {
              "type": "group",
              "id": "response_tokens",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "medium",
                "align": "center"
              },
              "children": [
                {
                  "type": "token",
                  "id": "status_token",
                  "content": "Was it success?"
                },
                {
                  "type": "token",
                  "id": "json_token",
                  "content": "What data came back?"
                }
              ]
            }
          ],
          "layout": {
            "type": "stack",
            "direction": "vertical",
            "gap": "large",
            "align": "center"
          }
        },
        {
          "type": "connector",
          "id": "payload_to_response",
          "from": "payload_box",
          "to": "response_box"
        },
        {
          "type": "connector",
          "id": "response_to_client_ui",
          "from": "response_box",
          "to": "client_result"
        }
      ],
      "animations": [
