    {
      "id": "validation_and_auth",
      "duration": "15s",
      "template": "one-column",
      "auto_visible": false,
      "include_persistent_objects": true,
      "narration": "When that GET slash users slash forty-two request reaches the server, the API does not jump straight to the database. First it checks the bearer token to confirm who is calling, then it validates that the route and request shape make sense. This matters because bad or unauthorized requests get stopped early with a fast 401 or 400 instead of wasting deeper work.",
      "objects": [
        {
          "type": "group",
          "id": "validation_scene",
          "visible": true,
          "children": [
            {
              "type": "text",
              "id": "validation_title",
              "content": "2. The server validates the request",
              "style": "heading"
            },
            {
              "type": "group",
              "id": "validation_flow",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "large",
                "align": "center"
              },
              "children": [
                {
                  "type": "box",
                  "id": "request_summary",
                  "content": "GET /users/42"
                },
                {
                  "type": "box",
                  "id": "auth_box",
                  "content": "Check bearer token"
                },
                {
                  "type": "box",
                  "id": "validation_box",
                  "content": "Check route and shape"
                },
                {
                  "type": "box",
                  "id": "handler_ready",
                  "content": "Pass to handler"
                }
              ]
            },
            {
              "type": "group",
              "id": "error_tokens",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "medium",
                "align": "center"
              },
              "children": [
                {
                  "type": "token",
                  "id": "auth_fail_token",
                  "content": "401 if token fails"
                },
                {
                  "type": "token",
                  "id": "validation_fail_token",
                  "content": "400 if route is wrong"
                }
              ]
            }
          ],
          "layout": {
            "type": "stack",
            "direction": "vertical",
            "gap": "large",
            "align": "center"
          }
        },
        {
          "type": "connector",
          "id": "request_to_auth",
          "from": "request_summary",
          "to": "auth_box"
        },
        {
          "type": "connector",
          "id": "auth_to_validation",
          "from": "auth_box",
          "to": "validation_box"
        },
        {
          "type": "connector",
          "id": "validation_to_handler",
          "from": "validation_box",
          "to": "handler_ready"
        }
      ],
