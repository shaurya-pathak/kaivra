          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "database_box",
          "at": "4.4s",
          "duration": "0.8s"
        },
        {
          "action": "highlight",
          "target": "database_box",
          "at": "5.2s",
          "duration": "1.3s",
          "style": "glow",
          "color": "success"
        },
        {
          "action": "fade-in",
          "target": "database_note",
          "at": "6.3s",
          "duration": "0.7s"
        },
        {
          "action": "draw",
