        {
          "action": "fade-in",
          "target": "request_title",
          "at": "0s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "client_box",
          "at": "0.6s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "request_summary",
          "at": "1.4s",
          "duration": "0.8s"
        },
        {
          "action": "draw",
          "target": "client_to_request",
          "at": "2.1s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "endpoint_card",
          "at": "2.7s",
          "duration": "0.8s"
        },
        {
          "action": "draw",
          "target": "request_to_endpoint",
          "at": "3.4s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "method_token",
          "at": "4.3s",
          "duration": "0.7s"
        },
        {
          "action": "fade-in",
          "target": "header_token",
          "at": "4.9s",
          "duration": "0.7s"
        },
        {
          "action": "fade-in",
          "target": "body_token",
          "at": "5.5s",
          "duration": "0.7s"
        },
        {
          "action": "highlight",
          "target": "request_summary",
          "at": "6.5s",
          "duration": "1.8s",
          "style": "glow",
          "color": "accent"
        }
