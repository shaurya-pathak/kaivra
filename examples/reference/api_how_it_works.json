    {
      "id": "business_logic",
      "duration": "12s",
      "template": "one-column",
      "auto_visible": false,
      "include_persistent_objects": true,
      "narration": "Now the request is trusted, so the users handler can do the actual work. This is the step that turns a generic HTTP request into the exact product result the app needs. In our example, the handler asks what fields this caller may see, loads user forty-two from the database, and shapes that record into a clean API payload instead of leaking raw database details.",
      "objects": [
        {
          "type": "group",
          "id": "logic_scene",
          "visible": true,
          "children": [
            {
              "type": "text",
              "id": "logic_title",
              "content": "3. The application does the real work",
              "style": "heading"
            },
            {
              "type": "group",
              "id": "logic_flow",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "large",
                "align": "center"
              },
              "children": [
                {
                  "type": "box",
                  "id": "handler_ready",
                  "content": "Users handler"
                },
                {
                  "type": "box",
                  "id": "service_box",
                  "content": "Choose safe fields"
                },
                {
                  "type": "box",
                  "id": "database_box",
                  "content": "Load user 42"
                },
                {
                  "type": "box",
                  "id": "payload_box",
                  "content": "API payload\n{id:42,name:\"Ava\"}"
                }
              ]
            },
            {
              "type": "group",
              "id": "logic_notes",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "medium",
                "align": "center"
              },
              "children": [
                {
                  "type": "token",
                  "id": "service_note",
                  "content": "Permissions"
                },
                {
                  "type": "token",
                  "id": "database_note",
                  "content": "Database row"
                }
              ]
            }
          ],
          "layout": {
            "type": "stack",
            "direction": "vertical",
            "gap": "large",
            "align": "center"
          }
        },
        {
          "type": "connector",
          "id": "handler_to_service",
          "from": "handler_ready",
          "to": "service_box"
        },
        {
          "type": "connector",
          "id": "service_to_database",
          "from": "service_box",
          "to": "database_box"
        },
        {
          "type": "connector",
          "id": "database_to_payload",
          "from": "database_box",
          "to": "payload_box"
        }
      ],
      "animations": [
