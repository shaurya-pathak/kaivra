          "at": "1.5s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "auth_box",
          "at": "2.0s",
          "duration": "0.8s"
        },
        {
          "action": "highlight",
          "target": "auth_box",
          "at": "2.9s",
          "duration": "1.3s",
          "style": "glow",
          "color": "warning"
        },
        {
          "action": "draw",
          "target": "auth_to_validation",
          "at": "4.1s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "validation_box",
          "at": "4.6s",
          "duration": "0.8s"
        },
        {
          "action": "highlight",
          "target": "validation_box",
          "at": "5.5s",
          "duration": "1.5s",
          "style": "glow",
          "color": "accent"
        },
        {
          "action": "draw",
          "target": "validation_to_handler",
          "at": "6.8s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "handler_ready",
          "at": "7.4s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "auth_fail_token",
          "at": "8.4s",
          "duration": "0.7s"
        },
        {
          "action": "fade-in",
