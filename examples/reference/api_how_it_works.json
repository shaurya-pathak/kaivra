  "scenes": [
    {
      "id": "client_request",
      "duration": "15s",
      "template": "one-column",
      "auto_visible": false,
      "include_persistent_objects": true,
      "narration": "Let's walk one request all the way through. Imagine the app needs the profile for user forty-two, so it sends GET slash users slash forty-two to the users API. GET means read, the path picks the exact record, the auth header identifies the caller, and for this example there is no body because we are only fetching data.",
      "objects": [
        {
          "type": "group",
          "id": "request_scene",
          "visible": true,
          "children": [
            {
              "type": "text",
              "id": "request_title",
              "content": "1. The client packages a request",
              "style": "heading"
            },
            {
              "type": "group",
              "id": "request_flow",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "large",
                "align": "center"
              },
              "children": [
                {
                  "type": "box",
                  "id": "client_box",
                  "content": "Client"
                },
                {
                  "type": "box",
                  "id": "request_summary",
                  "content": "GET /users/42"
                },
                {
                  "type": "box",
                  "id": "endpoint_card",
                  "content": "Users API"
                }
              ]
            },
            {
              "type": "group",
              "id": "request_parts",
              "visible": true,
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "medium",
                "align": "center"
              },
              "children": [
                {
                  "type": "token",
                  "id": "method_token",
                  "content": "GET means read"
                },
                {
                  "type": "token",
                  "id": "header_token",
                  "content": "Bearer token"
                },
                {
                  "type": "token",
                  "id": "body_token",
                  "content": "No body for GET"
                }
              ]
            }
          ],
          "layout": {
            "type": "stack",
            "direction": "vertical",
            "gap": "large",
            "align": "center"
          }
        },
        {
          "type": "connector",
          "id": "client_to_request",
          "from": "client_box",
          "to": "request_summary"
        },
        {
          "type": "connector",
          "id": "request_to_endpoint",
          "from": "request_summary",
          "to": "endpoint_card"
        }
      ],
      "animations": [
        {
          "action": "highlight",
