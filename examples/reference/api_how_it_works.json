        },
        {
          "action": "fade-in",
          "target": "service_box",
          "at": "2.0s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
          "target": "service_note",
          "at": "2.9s",
          "duration": "0.7s"
        },
        {
          "action": "draw",
