          "at": "0.1s",
          "duration": "0.8s",
          "scale_factor": 1.12
        },
        {
          "action": "fade-in",
          "target": "logic_title",
          "at": "0s",
          "duration": "0.8s"
        },
        {
          "action": "fade-in",
