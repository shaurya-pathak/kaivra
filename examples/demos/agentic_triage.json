        {
          "action": "move-to",
          "target": "runner",
          "to_id": "t_db",
          "at": "2.8s",
          "duration": "0.6s",
          "translate": { "x": -1.0 }
        },
        {
          "action": "move-to",
          "target": "runner",
          "to_id": "t_ui",
          "at": "3.6s",
          "duration": "0.6s",
          "translate": { "x": -1.0 }
        },
        {
          "action": "move-to",
          "target": "runner",
          "to_id": "t_checkout",
          "at": "4.4s",
          "duration": "0.8s",
          "translate": { "x": -1.0 }
        },
        {
          "action": "pulse",
          "target": "runner",
          "at": "5.6s",
          "duration": "1.4s"
        }
      ]
    },
    {
      "id": "test_fail",
      "duration": "8s",
      "template": "two-column",
      "narration": "The pipeline pauses on a single failing test. The triage agent spins up and traces the fault.",
      "objects": [
        {
          "type": "text",
          "id": "heading",
          "content": "Pipeline Paused \u2014 Failure Detected",
          "style": "heading"
        },
        {
          "type": "group",
          "id": "main",
          "grid": {
            "region": "main"
          },
          "layout": {
            "type": "stack",
            "gap": "small",
            "align": "center"
          },
          "children": [
            {
              "type": "token",
              "id": "f_api",
              "content": "PASS  test_api_response"
            },
            {
              "type": "token",
              "id": "f_auth",
              "content": "PASS  test_auth_flow"
            },
            {
              "type": "token",
              "id": "f_db",
