        {
          "action": "fade-in",
          "target": "main",
          "at": "0.2s",
          "duration": "1.2s"
        },
        {
          "action": "scale",
          "target": "main",
          "at": "0.4s",
          "duration": "1.0s",
          "scale_factor": 1.04
        },
        {
          "action": "scale",
          "target": "main",
          "at": "1.8s",
          "duration": "0.8s",
          "scale_factor": 1.0
        },
        {
          "action": "highlight",
          "target": "step_run",
          "at": "0s",
          "duration": "9.5s",
          "style": "glow",
          "color": "accent"
        },
        {
          "action": "scale",
          "target": "step_run",
          "at": "0.2s",
          "duration": "0.8s",
          "scale_factor": 1.18
        },
        {
          "action": "scale",
          "target": "step_run",
          "at": "2.0s",
          "duration": "0.6s",
          "scale_factor": 1.0
        },
        {
          "action": "highlight",
