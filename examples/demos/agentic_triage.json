{
  "version": "1.3",
  "meta": {
    "title": "Agentic Test Triage",
    "resolution": [
      1920,
      1080
    ],
    "fps": 30,
    "theme": "modern"
  },
  "objects": [
    {
      "type": "group",
      "id": "carousel",
      "position": "bottom",
      "layout": {
        "type": "flow",
        "direction": "horizontal",
        "gap": "medium",
        "align": "center"
      },
      "children": [
        {
          "type": "token",
          "id": "step_run",
          "content": "1  Run tests"
        },
        {
          "type": "token",
          "id": "step_fail",
          "content": "2  Detect failure"
        },
        {
          "type": "token",
          "id": "step_logs",
          "content": "3  Read logs"
        },
        {
          "type": "token",
          "id": "step_decide",
          "content": "4  Decide cause"
        },
        {
          "type": "token",
          "id": "step_fix",
          "content": "5  Write fix"
        },
        {
          "type": "token",
          "id": "step_mr",
          "content": "6  Open MR"
        },
        {
          "type": "token",
          "id": "step_resume",
          "content": "7  Resume pipeline"
        }
      ]
    }
  ],
  "scenes": [
    {
      "id": "tests_running",
      "duration": "10s",
      "template": "two-column",
      "narration": "A CI/CD pipeline kicks off. Five tests spin up \u2014 the first four pass, the last one stumbles.",
      "objects": [
        {
          "type": "text",
          "id": "heading",
          "content": "Test Suite Running",
          "style": "heading"
        },
        {
          "type": "group",
          "id": "main",
          "grid": {
            "region": "main"
          },
          "layout": {
            "type": "stack",
            "gap": "small",
            "align": "center"
          },
          "children": [
            {
              "type": "token",
              "id": "t_api",
              "content": "test_api_response"
            },
            {
              "type": "token",
              "id": "t_auth",
              "content": "test_auth_flow"
            },
            {
              "type": "token",
              "id": "t_db",
              "content": "test_db_write"
            },
            {
              "type": "token",
              "id": "t_ui",
              "content": "test_ui_login"
            },
            {
              "type": "token",
              "id": "t_checkout",
              "content": "test_e2e_checkout"
            }
          ]
        },
        {
          "type": "circle",
          "id": "runner",
          "content": "AI"
        }
      ],
      "animations": [
        {
          "action": "fade-in",
          "target": "heading",
