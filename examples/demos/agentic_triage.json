    {
      "id": "agent_fix",
      "duration": "9s",
      "template": "two-column",
      "narration": "The agent writes the fix: a session-scoped fixture that clears port 4444 before and after each run.",
      "objects": [
        {
          "type": "text",
          "id": "heading",
          "content": "Agent Writing Fix",
          "style": "heading"
        },
        {
          "type": "group",
          "id": "main",
          "grid": {
            "region": "main"
          },
          "layout": {
            "type": "stack",
            "gap": "small",
            "align": "center"
          },
          "children": [
            {
              "type": "token",
              "id": "fix0",
              "content": "# conftest.py"
            },
            {
              "type": "token",
              "id": "fix1",
              "content": "@pytest.fixture(scope='session', autouse=True)"
            },
            {
              "type": "token",
              "id": "fix2",
              "content": "def release_webdriver_port():"
            },
            {
              "type": "token",
              "id": "fix3",
              "content": "    kill_process_on_port(4444)"
            },
            {
              "type": "token",
              "id": "fix4",
              "content": "    yield"
            },
            {
              "type": "token",
              "id": "fix5",
              "content": "    kill_process_on_port(4444)"
            }
