          "duration": "1.0s"
        },
        {
          "action": "scale",
          "target": "main",
          "at": "0.6s",
          "duration": "0.8s",
          "scale_factor": 1.03
        },
        {
          "action": "scale",
          "target": "main",
          "at": "1.8s",
          "duration": "0.6s",
          "scale_factor": 1.0
        },
        {
          "action": "highlight",
