    {
      "id": "decision",
      "duration": "8s",
      "template": "two-column",
      "narration": "Verdict: automation failure. The WebDriver port conflict is test infrastructure, not application code.",
      "objects": [
        {
          "type": "text",
          "id": "heading",
          "content": "Root Cause: Automation Failure",
          "style": "heading"
        },
        {
          "type": "group",
          "id": "main",
          "grid": {
            "region": "main"
          },
          "layout": {
            "type": "stack",
            "gap": "large",
            "align": "center"
          },
          "children": [
            {
              "type": "group",
              "id": "options",
              "layout": {
                "type": "flow",
                "direction": "horizontal",
                "gap": "large",
                "align": "center"
              },
              "children": [
                {
                  "type": "box",
                  "id": "opt_code",
                  "content": "Code Bug"
