          "color": "success",
          "stagger": "0.6s"
        },
        {
          "action": "highlight",
          "target": "t_checkout",
          "at": "5.2s",
          "duration": "2.8s",
          "style": "glow",
          "color": "error"
        },
        {
          "action": "fade-in",
          "target": "runner",
          "at": "1.0s",
          "duration": "0.8s"
        },
        {
          "action": "move-to",
          "target": "runner",
          "to_id": "t_api",
          "at": "1.2s",
          "duration": "0.6s",
          "translate": { "x": -1.0 }
        },
        {
          "action": "move-to",
          "target": "runner",
          "to_id": "t_auth",
          "at": "2.0s",
          "duration": "0.6s",
