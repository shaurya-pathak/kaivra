        {
          "action": "move",
          "target": "f_checkout",
          "at": "5.0s",
          "duration": "0.1s",
          "translate": { "x": 0.04 }
        },
        {
          "action": "move",
          "target": "f_checkout",
          "at": "5.1s",
          "duration": "0.1s",
          "translate": { "x": -0.04 }
        },
        {
          "action": "move",
          "target": "f_checkout",
          "at": "5.2s",
          "duration": "0.1s",
          "translate": { "x": 0.03 }
        },
        {
          "action": "move",
          "target": "f_checkout",
