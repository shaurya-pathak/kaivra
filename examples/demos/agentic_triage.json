          "style": "heading"
        },
        {
          "type": "group",
          "id": "main",
          "grid": {
            "region": "main"
          },
          "layout": {
            "type": "stack",
            "gap": "small",
            "align": "center"
          },
          "children": [
            {
              "type": "token",
