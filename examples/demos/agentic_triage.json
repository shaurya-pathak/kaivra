          "style": "glow",
          "color": "success",
          "stagger": "0.4s"
        },
        {
          "action": "highlight",
          "target": "f_checkout",
          "at": "3.2s",
          "duration": "3.2s",
          "style": "glow",
          "color": "error"
        },
        {
          "action": "pulse",
          "target": "f_checkout",
          "at": "3.4s",
          "duration": "1.6s"
        },
        {
          "action": "move",
