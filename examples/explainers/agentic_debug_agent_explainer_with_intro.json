    {
      "id": "automation_remediation",
      "duration": "12s",
      "template": "one-column",
      "narration": "If the logs show automation failure, like a blocked port, stale browser session, or leaked fixture, the agent can repair it right away. It resets the machine, hardens the harness, and makes the environment healthy again.",
      "focus": "fix_box",
      "focus_style": {
        "at": "5.4s",
        "duration": "2.0s",
        "scale": 1.08,
        "color": "success"
      },
      "objects": [
